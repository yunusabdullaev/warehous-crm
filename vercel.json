{
    "version": 2,
    "builds": [
        {
            "src": "api/**/*.go",
            "use": "@vercel/go@3.2.4",
            "config": {
                "maxLambdaSize": "50mb"
            }
        },
        {
            "src": "package.json",
            "use": "@vercel/next"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.go"
        }
    ]
}
