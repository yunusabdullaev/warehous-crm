{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/$1"
        }
    ],
    "functions": {
        "api/*.go": {
            "runtime": "@vercel/go@3.2.4"
        }
    },
    "buildCommand": "cd frontend && npm install && npm run build",
    "outputDirectory": "frontend/out"
}