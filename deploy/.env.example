# ═══════════════════════════════════════════════════
#  Warehouse CRM — Production Environment Variables
# ═══════════════════════════════════════════════════
#  Copy to .env and fill in real values:
#    cp .env.example .env
#
#  Generate secrets:
#    openssl rand -base64 48   (for JWT_SECRET)
#    openssl rand -base64 32   (for MONGO_PASSWORD)

# ── Domain ──
DOMAIN=wms.example.com

# ── MongoDB ──
MONGO_USER=wmsadmin
MONGO_PASSWORD=CHANGE_ME_USE_openssl_rand_base64_32
MONGO_DB=warehouse_crm
# Full URI built from above (used by backend container)
MONGO_URI=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@mongodb:27017/${MONGO_DB}?authSource=admin

# ── Backend (Go/Fiber) ──
APP_PORT=3000
JWT_SECRET=CHANGE_ME_USE_openssl_rand_base64_48_MIN_64_CHARS
JWT_EXPIRY_HOURS=24
CORS_ORIGINS=https://wms.example.com

# ── Auth Hardening ──
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30
COOKIE_DOMAIN=wms.example.com
COOKIE_SECURE=true
COOKIE_SAMESITE=Lax

# ── Stripe Billing ──
# Use sk_test_ keys for staging, sk_live_ for production
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
BILLING_SUCCESS_URL=https://wms.example.com/billing?success=true
BILLING_CANCEL_URL=https://wms.example.com/billing?canceled=true
# Set to true ONLY for offline webhook tests, NEVER in production
STRIPE_WEBHOOK_TEST=false

# ── Tenant Cache ──
# TTL in seconds for tenant config cache. 0 = disabled (useful for testing)
TENANT_CACHE_TTL_SECONDS=60

# ── Frontend (Next.js) ──
# This is baked into the image at build time
NEXT_PUBLIC_API_BASE_URL=https://wms.example.com/api/v1

# ── Grafana ──
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=CHANGE_ME_grafana_admin_password

# ── Backups ──
BACKUP_DIR=/opt/wms/backups
BACKUP_RETENTION_DAYS=14
# S3 upload (optional — leave empty to skip)
S3_BUCKET=
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Telegram (optional — runtime settings in DB override these) ──
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=

# ── Docker image tags ──
BACKEND_IMAGE=ghcr.io/YOUR_ORG/wms-backend:latest
FRONTEND_IMAGE=ghcr.io/YOUR_ORG/wms-frontend:latest
